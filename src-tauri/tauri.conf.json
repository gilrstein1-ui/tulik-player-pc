{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TulikPlayer",
  "version": "1.0.3",
  "identifier": "org.tulik.player",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "tulik player",
        "width": 1200,
        "height": 820,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
